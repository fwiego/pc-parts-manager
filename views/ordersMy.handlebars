<div class="page-header">
  <h1>Мои заказы</h1>
  <p>История заявок и их текущий статус</p>
</div>

{{#if orders.length}}
<div style="display:flex; flex-direction:column; gap:1rem;">
{{#each orders}}
<div class="card" style="padding:0;">

  {{!-- Шапка --}}
  <div style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.5rem; border-bottom:1px solid var(--border); flex-wrap:wrap; gap:0.5rem;">
    <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
      <span class="mono">Заказ #{{this.user_order_num}}</span>
      {{#if (eq this.status "pending")}}
        <span class="badge" style="background:rgba(136,146,164,0.15); color:var(--muted);">🕐 Ожидает обработки</span>
      {{/if}}
      {{#if (eq this.status "processing")}}
        <span class="badge badge-admin">⚙️ В обработке</span>
      {{/if}}
      {{#if (eq this.status "ready")}}
        <span class="badge" style="background:rgba(247,167,79,0.15); color:var(--warn);">📦 Готов к выдаче</span>
      {{/if}}
      {{#if (eq this.status "issued")}}
        <span class="badge badge-manager">✅ Выдан</span>
      {{/if}}
      {{#if (eq this.status "rejected")}}
        <span class="badge" style="background:rgba(247,92,92,0.15); color:var(--danger);">❌ Отклонён</span>
      {{/if}}
    </div>
    <span class="mono" style="color:var(--muted); font-size:0.82rem;">{{this.order_date}}</span>
  </div>

  {{!-- Позиции --}}
  <div style="padding:0.5rem 0;">
    {{#each this.items}}
    <div style="display:flex; align-items:center; gap:1rem; padding:0.6rem 1.5rem; border-bottom:1px solid var(--border); flex-wrap:wrap;">
      <div style="flex:1; min-width:160px;">
        <div style="font-weight:600; font-size:0.88rem;">{{this.component_name}}</div>
        <div style="color:var(--muted); font-size:0.78rem;">{{this.manufacturer}} · {{this.category}}</div>
      </div>
      <div class="mono" style="font-size:0.85rem;">{{this.quantity}} шт.</div>
      {{!-- Ячейку не показываем, только для статуса ready показываем подсказку --}}
      {{#if (eq ../status "ready")}}
        <span style="font-size:0.78rem; color:var(--accent2);">Можно забрать</span>
      {{/if}}
    </div>
    {{/each}}
  </div>

</div>
{{/each}}
</div>
{{else}}
  <div class="card" style="text-align:center; padding:3rem; color:var(--muted);">
    Заказов пока нет
  </div>
{{/if}}

<div class="btn-group">
  <a href="/dashboard" class="btn btn-primary">+ Новый заказ</a>
  <a href="/" class="btn btn-ghost">На главную</a>
</div>
