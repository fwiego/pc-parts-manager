<div class="page-header">
  <h1>Мои заказы</h1>
  <p>История ваших заявок на комплектующие</p>
</div>

<div class="card">
  {{#if orders.length}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Комплектующая</th>
          <th>Производитель</th>
          <th>Количество</th>
          <th>Статус</th>
          <th>Дата</th>
        </tr>
      </thead>
      <tbody>
        {{#each orders}}
        <tr>
          <td class="mono">{{this.order_id}}</td>
          <td style="font-weight:600;">{{this.component_name}}</td>
          <td style="color:var(--muted);">{{this.manufacturer}}</td>
          <td class="mono">{{this.quantity}} шт.</td>
          <td>
            {{#if (eq this.status "pending")}}
              <span class="badge" style="background:rgba(247,167,79,0.15); color:var(--warn);">⏳ Ожидает</span>
            {{/if}}
            {{#if (eq this.status "approved")}}
              <span class="badge badge-manager">✅ Одобрен</span>
            {{/if}}
            {{#if (eq this.status "rejected")}}
              <span class="badge" style="background:rgba(247,92,92,0.15); color:var(--danger);">❌ Отклонён</span>
            {{/if}}
          </td>
          <td class="mono" style="color:var(--muted);">{{this.order_date}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
    <p style="color:var(--muted); text-align:center; padding:2rem 0;">У вас пока нет заказов</p>
  {{/if}}

  <div class="btn-group">
    <a href="/orders/create" class="btn btn-primary">+ Новый заказ</a>
    <a href="/" class="btn btn-ghost">На главную</a>
  </div>
</div>
