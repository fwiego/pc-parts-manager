<div class="page-header">
  <h1>Каталог комплектующих</h1>
  <p>Выберите позиции и оформите заказ через корзину</p>
</div>

<div style="display:grid; grid-template-columns:1fr 320px; gap:1.5rem; align-items:start;">

  {{!-- ─── КАТАЛОГ ─── --}}
  <div>

    {{!-- Фильтры --}}
    <div class="card" style="padding:1rem 1.5rem; margin-bottom:1rem;">
      <form method="GET" action="/dashboard" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:flex-end;">
        <div>
          <label style="margin-bottom:0.3rem;">Категория</label>
          <select name="category" style="width:180px;">
            <option value="">Все категории</option>
            {{#each categories}}
              <option value="{{this}}" {{#if (eq this ../currentCategory)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
        </div>
        <div>
          <label style="margin-bottom:0.3rem;">Сортировка</label>
          <select name="sort" style="width:180px;">
            <option value="">По умолчанию</option>
            <option value="price_asc"  {{#if (eq currentSort "price_asc")}}selected{{/if}}>Цена ↑</option>
            <option value="price_desc" {{#if (eq currentSort "price_desc")}}selected{{/if}}>Цена ↓</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self:flex-end;">Применить</button>
        <a href="/dashboard" class="btn btn-ghost" style="align-self:flex-end;">Сбросить</a>
        <a href="/" class="btn btn-ghost" style="align-self:flex-end;">На главную</a>
      </form>
    </div>

    {{!-- Список --}}
    {{#if components.length}}
    <div style="display:grid; gap:0.6rem;">
      {{#each components}}
      <div class="card" style="padding:1rem 1.25rem; display:flex; align-items:center; gap:1rem;">
        <div style="flex:1; min-width:0;">
          <div style="display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap;">
            <span style="font-weight:700;">{{this.name}}</span>
            <span class="badge badge-user" style="font-size:0.7rem;">{{this.category}}</span>
          </div>
          <div style="color:var(--muted); font-size:0.83rem; margin-top:0.2rem;">
            {{this.manufacturer}}{{#if this.model}} · {{this.model}}{{/if}}
          </div>
          <div style="font-size:0.8rem; margin-top:0.3rem; color:var(--muted);">
            В наличии: <strong style="color:var(--text);">{{this.quantity}} шт.</strong>
          </div>
        </div>
        <div style="text-align:right; flex-shrink:0;">
          <div style="font-size:1.1rem; font-weight:700; color:var(--accent2); margin-bottom:0.5rem;">
            {{this.price}} ₽
          </div>
          <div style="display:flex; align-items:center; gap:0.4rem;">
            <input type="number" min="1" max="{{this.quantity}}" value="1"
                   id="qty-{{this.component_id}}"
                   style="width:60px; padding:0.3rem 0.5rem; font-size:0.85rem; text-align:center;">
            <button class="btn btn-success"
                    style="padding:0.35rem 0.75rem; font-size:0.82rem;"
                    onclick="addToCart({{this.component_id}}, '{{this.name}}', {{this.price}}, {{this.quantity}})">
              + В корзину
            </button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
      <div class="card" style="text-align:center; padding:3rem; color:var(--muted);">
        Нет доступных позиций
      </div>
    {{/if}}

  </div>

  {{!-- ─── КОРЗИНА ─── --}}
  <div style="position:sticky; top:72px;">
    <div class="card">
      <div style="font-weight:700; font-size:1rem; margin-bottom:1.25rem; display:flex; justify-content:space-between; align-items:center;">
        <span>🛒 Корзина</span>
        <span id="cart-count" style="font-size:0.8rem; color:var(--muted);">0 позиций</span>
      </div>

      <div id="cart-empty" style="color:var(--muted); font-size:0.88rem; text-align:center; padding:1.5rem 0;">
        Добавьте позиции из каталога
      </div>

      <div id="cart-items" style="display:none; margin-bottom:1rem;"></div>

      <div id="cart-total" style="display:none; border-top:1px solid var(--border); padding-top:0.85rem; margin-bottom:1rem;">
        <div style="display:flex; justify-content:space-between; font-weight:700;">
          <span>Итого:</span>
          <span id="total-price" style="color:var(--accent2);">0 ₽</span>
        </div>
      </div>

      <form id="order-form" action="/orders/create" method="POST" style="display:none;">
        <input type="hidden" name="items" id="cart-input">
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
          Оформить заказ
        </button>
      </form>

      <button id="cart-clear" onclick="clearCart()"
              style="display:none; width:100%; margin-top:0.5rem;"
              class="btn btn-ghost">
        Очистить корзину
      </button>
    </div>
  </div>

</div>

<script>
  let cart = {};

  function addToCart(id, name, price, maxQty) {
    const qty = parseInt(document.getElementById('qty-' + id).value) || 1;
    if (qty < 1 || qty > maxQty) { showToast('Недопустимое количество', 'error'); return; }

    if (cart[id]) {
      const newQty = cart[id].quantity + qty;
      if (newQty > maxQty) { showToast('Превышает доступное количество (' + maxQty + ' шт.)', 'error'); return; }
      cart[id].quantity = newQty;
    } else {
      cart[id] = { name, price, quantity: qty, maxQty };
    }
    renderCart();
    showToast('«' + name + '» добавлен в корзину', 'success');
    document.getElementById('qty-' + id).value = 1;
  }

  function removeFromCart(id) { delete cart[id]; renderCart(); }
  function clearCart()        { cart = {};        renderCart(); }

  function renderCart() {
    const ids      = Object.keys(cart);
    const countEl  = document.getElementById('cart-count');
    const emptyEl  = document.getElementById('cart-empty');
    const itemsEl  = document.getElementById('cart-items');
    const totalEl  = document.getElementById('cart-total');
    const formEl   = document.getElementById('order-form');
    const clearEl  = document.getElementById('cart-clear');
    const priceEl  = document.getElementById('total-price');
    const inputEl  = document.getElementById('cart-input');

    const endings = [' позиция', ' позиции', ' позиций'];
    const n = ids.length % 100;
    const ending = (n >= 11 && n <= 19) ? endings[2] : [endings[2], endings[0], endings[1], endings[1], endings[1]][Math.min(n % 10, 4)];
    countEl.textContent = ids.length + ending;

    if (ids.length === 0) {
      emptyEl.style.display = ''; itemsEl.style.display = 'none';
      totalEl.style.display = 'none'; formEl.style.display = 'none'; clearEl.style.display = 'none';
      return;
    }

    emptyEl.style.display = 'none'; itemsEl.style.display = '';
    totalEl.style.display = ''; formEl.style.display = ''; clearEl.style.display = '';

    let total = 0;
    itemsEl.innerHTML = '';
    ids.forEach(id => {
      const item = cart[id];
      const sub  = item.price * item.quantity;
      total += sub;
      const div = document.createElement('div');
      div.style.cssText = 'display:flex; justify-content:space-between; align-items:center; padding:0.5rem 0; border-bottom:1px solid var(--border); gap:0.5rem;';
      div.innerHTML = `
        <div style="flex:1; min-width:0;">
          <div style="font-size:0.85rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${item.name}</div>
          <div style="font-size:0.78rem; color:var(--muted);">${item.quantity} шт. × ${item.price} ₽</div>
        </div>
        <div style="display:flex; align-items:center; gap:0.4rem; flex-shrink:0;">
          <span style="font-size:0.85rem; font-weight:700; color:var(--accent2);">${sub} ₽</span>
          <button onclick="removeFromCart(${id})" style="background:none; border:none; color:var(--danger); cursor:pointer; font-size:1rem; padding:0.1rem 0.3rem;">✕</button>
        </div>`;
      itemsEl.appendChild(div);
    });

    priceEl.textContent = total.toLocaleString('ru-RU') + ' ₽';
    inputEl.value = JSON.stringify(ids.map(id => ({ component_id: parseInt(id), quantity: cart[id].quantity })));
  }
</script>
