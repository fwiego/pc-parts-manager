<div class="page-header">
  <h1>Отчёты менеджеров</h1>
  <p>Все транзакции по складу — поступления и списания</p>
</div>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem;">
    <span style="color:var(--muted); font-size:0.88rem;">
      Всего записей: <strong style="color:var(--text);">{{reports.length}}</strong>
    </span>
    <a href="/admin/adminReports/export" class="btn btn-success">
      ⬇ Скачать CSV
    </a>
  </div>

  {{#if reports.length}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Менеджер</th>
          <th>Комплектующая</th>
          <th>Производитель</th>
          <th>Тип операции</th>
          <th>Количество</th>
          <th>Дата</th>
        </tr>
      </thead>
      <tbody>
        {{#each reports}}
        <tr>
          <td class="mono">{{this.id}}</td>
          <td style="font-weight:600;">{{this.manager}}</td>
          <td>{{this.component_name}}</td>
          <td style="color:var(--muted);">{{this.manufacturer}}</td>
          <td>
            {{#if (eq this.type "issue")}}
              <span class="badge badge-issue">📥 Поступление</span>
            {{else}}
              <span class="badge badge-return">📤 Списание</span>
            {{/if}}
          </td>
          <td class="mono">{{this.quantity}} шт.</td>
          <td class="mono" style="color:var(--muted);">{{this.date}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
    <p style="color:var(--muted); text-align:center; padding:2rem 0;">Транзакций пока нет</p>
  {{/if}}

  <div class="btn-group">
    <a href="/" class="btn btn-ghost">На главную</a>
  </div>
</div>
