<div class="page-header">
  <h1>Создать заказ</h1>
  <p>Выберите комплектующую и укажите нужное количество</p>
</div>

<div style="max-width:580px;">
  <div class="card">
    <form action="/orders/create" method="POST">

      <div class="form-group">
        <label for="category-select">Категория</label>
        <select id="category-select" required>
          <option value="" disabled selected>— Выберите категорию —</option>
          {{#each categories}}
            <option value="{{@key}}">{{lookup ../categoryNames @key}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="component_id">Комплектующая</label>
        <select name="component_id" id="component_id" required disabled>
          <option value="" disabled selected>— Сначала выберите категорию —</option>
        </select>
      </div>

      <div class="form-group">
        <label for="quantity">Количество (шт.)</label>
        <input type="number" name="quantity" id="quantity" min="1" placeholder="Введите количество" required>
      </div>

      <div class="btn-group">
        <button type="submit" class="btn btn-primary">Оформить заказ</button>
        <a href="/" class="btn btn-ghost">Отмена</a>
      </div>

    </form>
  </div>
</div>

<script>
  const categoriesData  = {{{json categories}}};
  const categorySelect  = document.getElementById('category-select');
  const componentSelect = document.getElementById('component_id');

  categorySelect.addEventListener('change', () => {
    const cat = categorySelect.value;
    componentSelect.innerHTML = '<option value="" disabled selected>— Выберите комплектующую —</option>';
    componentSelect.disabled = true;

    if (categoriesData[cat]) {
      categoriesData[cat].forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.component_id;
        opt.textContent = `${c.name} — ${c.manufacturer}`;
        componentSelect.appendChild(opt);
      });
      componentSelect.disabled = false;
    }
  });
</script>
