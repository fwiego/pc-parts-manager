<div class="page-header">
  <h1>Менеджеры</h1>
  <p>Создание и удаление аккаунтов менеджеров склада</p>
</div>

<div style="display:grid; grid-template-columns: 1fr 340px; gap:1.5rem; align-items:start;">

  {{!-- Таблица менеджеров --}}
  <div class="card">
    {{#if managers.length}}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>ФИО</th>
            <th>Логин</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each managers}}
          <tr>
            <td class="mono">{{this.user_id}}</td>
            <td style="font-weight:600;">{{this.full_name}}</td>
            <td class="mono">{{this.login}}</td>
            <td style="text-align:right;">
              <form action="/users/{{this.user_id}}/delete" method="POST"
                    onsubmit="return confirm('Удалить менеджера «{{this.full_name}}»?')">
                <button type="submit" class="btn btn-danger"
                        style="padding:0.3rem 0.75rem; font-size:0.8rem;">
                  Удалить
                </button>
              </form>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
      <p style="color:var(--muted); text-align:center; padding:2rem 0;">
        Менеджеров пока нет — создайте первого →
      </p>
    {{/if}}

    <div class="btn-group">
      <a href="/" class="btn btn-ghost">На главную</a>
    </div>
  </div>

  {{!-- Форма создания --}}
  <div class="card" style="position:sticky; top:72px;">
    <div style="font-size:1rem; font-weight:700; margin-bottom:1.25rem;">
      Новый менеджер
    </div>
    <form action="/users/create" method="POST">
      <div class="form-group">
        <label for="full_name">ФИО</label>
        <input type="text" name="full_name" id="full_name"
               placeholder="Иванов Иван Иванович" required>
      </div>
      <div class="form-group">
        <label for="login">Логин</label>
        <input type="text" name="login" id="login"
               placeholder="manager_ivanov" required>
      </div>
      <div class="form-group">
        <label for="password">Пароль</label>
        <input type="password" name="password" id="password"
               placeholder="Минимум 6 символов" required minlength="6">
      </div>
      <button type="submit" class="btn btn-success" style="width:100%; justify-content:center;">
        Создать менеджера
      </button>
    </form>
  </div>

</div>
